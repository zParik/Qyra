{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Qyra",
  "version": "0.1.0",
  "identifier": "com.parik.qyra",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Qyra",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: https://tauri.localhost ipc: http://ipc.localhost; script-src 'self' 'wasm-unsafe-eval' blob: tauri: https://tauri.localhost; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data: asset: https://asset.localhost tauri: https://tauri.localhost; font-src 'self' data:; connect-src ipc: http://ipc.localhost tauri: https://tauri.localhost; worker-src blob:;"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI3OTFGNTJENEUxOEVCOTQKUldTVTZ4aE9MZldSSjI1TnVqOVd5cUtkdnJoL0ZsMjd4UE9BT2ZqcjBRSHdDRldMa0Q0T0NkN3kK",
      "endpoints": [
        "https://github.com/zparik/qyra/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "name": "PDF Document",
        "description": "PDF Document",
        "mimeType": "application/pdf"
      }
    ]
  }
}
